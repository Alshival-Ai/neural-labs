# Server
PORT=3000
VITE_PUBLIC_APP_NAME=Neural Labs

# Desktop defaults
NEURAL_LABS_THEME=dark
NEURAL_LABS_BACKGROUND_ID=aurora

# Workspace backend
NEURAL_LABS_WORKSPACE_BACKEND=docker
NEURAL_LABS_WORKSPACE_IMAGE=ubuntu:24.04
NEURAL_LABS_WORKSPACE_SHELL=bash

# Provider bootstrap (optional)
# Default OpenAI-compatible provider config.
# For Azure AI Foundry (instead of api.openai.com/v1), set:
# OPENAI_DEFAULT_BASE_URL=https://<your-resource>.services.ai.azure.com/models
# OPENAI_DEFAULT_MODEL=<foundry-model-name>
# OPENAI_DEFAULT_API_KEY=<azure-foundry-key>
OPENAI_DEFAULT_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-5-mini
OPENAI_DEFAULT_NAME=OpenAI
OPENAI_DEFAULT_BASE_URL=https://api.openai.com/v1

# For AWS Bedrock Claude, use an Anthropic-compatible proxy that signs SigV4.
# Then point ANTHROPIC_DEFAULT_BASE_URL to that proxy endpoint.
# Example:
# ANTHROPIC_DEFAULT_BASE_URL=http://host.docker.internal:4000/anthropic
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
ANTHROPIC_DEFAULT_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-20250514
ANTHROPIC_DEFAULT_NAME=Anthropic
ANTHROPIC_DEFAULT_BASE_URL=https://api.anthropic.com/v1

NEURAL_LABS_DEFAULT_PROVIDER=openai
